{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "check:pages-size": "node tools/check-pages-size.mjs public",
    "clean": "hexo clean",
    "convert:png-webp": "node tools/convert-png-to-webp.mjs",
    "deploy": "npm run build",
    "preview": "npm run clean && npm run build && python tools/serve-public.py",
    "serve:public": "python tools/serve-public.py",
    "server": "hexo server"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
