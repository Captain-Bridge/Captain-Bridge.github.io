{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marathon.uesc.top/map/data/interactive-map.schema.json",
  "title": "Interactive Map Data",
  "type": "object",
  "required": ["mapId", "version", "pois"],
  "properties": {
    "mapId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "polygon"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "items": false
            }
          },
          "labelPosition": {
            "type": "array",
            "prefixItems": [
              {
                "type": "number"
              },
              {
                "type": "number"
              }
            ],
            "items": false
          },
          "fill": {
            "type": "string"
          },
          "stroke": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "pois": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "x", "y"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "description": {
            "type": "string"
          },
          "floor": {
            "type": "string"
          },
          "factionId": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "href"],
              "properties": {
                "label": {
                  "type": "string"
                },
                "href": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
